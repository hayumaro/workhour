<Window x:Class="workhour.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:workhour"
        mc:Ignorable="d"
        Title="MainWindow" Height="449" Width="408">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ショートカット -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
            <Button Width="Auto" Height="30" Margin="5,5,5,5" Content="事務" FontFamily="Noto Sans JP DemiLight" FontSize="14" Click="JimuButton_Click"/>
            <Button Width="Auto" Height="30" Margin="5,5,5,5" Content="部会" FontFamily="Noto Sans JP DemiLight" FontSize="14" Click="InnerMtgButton_Click"/>
            <Button Width="30" Height="30" Margin="5,5,5,5" Content="PC" FontFamily="Noto Sans JP DemiLight" FontSize="14" Click="PcSetupButton_Click"/>
        </StackPanel>

        <!-- 作業内容 -->
        <TextBox Grid.Row="1"
                 x:Name="WorkContent"
                 HorizontalAlignment="Stretch"
                 Margin="0,0,0,5"
                 TextWrapping="Wrap"
                 FontFamily="Noto Sans JP DemiLight"
                 FontSize="16"/>

        <!-- 作業区分 -->
        <ComboBox Grid.Row="2"
                  ItemsSource="{Binding WorkCases}"
                  HorizontalAlignment="Stretch"
                  Margin="0,0,0,5"
                  FontFamily="Noto Sans JP DemiLight"
                  FontSize="16"/>

        <!-- 開始／終了ボタン -->
        <Button Grid.Row="3"
                x:Name="RecordButton"
                Content="開始"
                HorizontalAlignment="Stretch"
                Margin="0,0,0,5"
                FontFamily="Noto Sans JP DemiLight"
                FontSize="20"
                Click="RecordButton_Click"
                Background="#FFBFE4CA"/>

        <!-- 記録一覧 -->
        <ListView Grid.Row="4"
                  ItemsSource="{Binding Works}"
                  FontFamily="Noto Sans JP DemiLight"
                  FontSize="14"
                  d:ItemsSource="{d:SampleData ItemCount=5}">

            <ListView.View>
                <GridView>
                    <GridViewColumn Header="内容" DisplayMemberBinding="{Binding Content}" />
                    <GridViewColumn Header="開始" DisplayMemberBinding="{Binding Begin, StringFormat=HH:mm}" />
                    <GridViewColumn Header="終了" DisplayMemberBinding="{Binding End, StringFormat=HH:mm}" />
                    <GridViewColumn Header="工数" DisplayMemberBinding="{Binding Hour, StringFormat=hh\\:mm}" />
                </GridView>
            </ListView.View>
        </ListView>

        <StatusBar Grid.Row="5">
            <TextBlock x:Name="StatusText" Text="準備完了"/>
        </StatusBar>
    </Grid>
</Window>