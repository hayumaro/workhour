<Window x:Class="workhour.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WorkHour"
        Height="460" Width="420"
        Background="#FFffffff"
        FontFamily="Noto Sans JP DemiLight">

    <Window.Resources>

        <!-- 角丸ボタン -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FFF3F4F7"/>
            <Setter Property="BorderBrush" Value="#00000000"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Background" Value="#FFF3F4F7"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="Black"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">

                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- 選択中 -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#FFDFF5E1"/>
                                <Setter TargetName="border" Property="Background" Value="#FFE3E4E7"/>
                            </Trigger>

                            <!-- ホバー -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFE3E4E7"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD6D6D6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- ListView -->
        <Style TargetType="ListView">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
        </Style>

    </Window.Resources>

    <Grid Margin="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: ショートカット -->
            <RowDefinition Height="Auto"/>
            <!-- 1: ボタン群（ComboBox置換） -->
            <RowDefinition Height="Auto"/>
            <!-- 2: 入力 -->
            <RowDefinition Height="Auto"/>
            <!-- 3: 開始 -->
            <RowDefinition Height="*"/>
            <!-- 4: ListView -->
            <RowDefinition Height="Auto"/>
            <!-- 5: Status -->
        </Grid.RowDefinitions>

        <!-- ショートカット -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="事務" Click="ShortcutButtons_Click"/>
            <Button Content="部会" Click="ShortcutButtons_Click"/>
            <Button Content="PC" Click="ShortcutButtons_Click"/>
            <Button Content="点検" Click="ShortcutButtons_Click"/>
            <Button Content="問い合わせ" Click="ShortcutButtons_Click"/>
        </StackPanel>

        <!-- 入力 -->
        <TextBox Grid.Row="1"
                 x:Name="WorkContent"
                 FontSize="15"
                 Height="32"/>

        <!-- 作業区分 -->
        <WrapPanel x:Name="WorkCasePanel" Grid.Row="2" Margin="0,0,0,8">
            <RadioButton Content="打ち合わせ" GroupName="WorkCase"/>
            <RadioButton Content="実装" GroupName="WorkCase"/>
            <RadioButton Content="テスト" GroupName="WorkCase"/>
            <RadioButton Content="教育" GroupName="WorkCase"/>
            <RadioButton Content="調査" GroupName="WorkCase"/>
            <RadioButton Content="資料" GroupName="WorkCase"/>
            <RadioButton Content="定例" GroupName="WorkCase"/>
            <RadioButton Content="環境構築" GroupName="WorkCase"/>
            <RadioButton Content="ハード管理" GroupName="WorkCase"/>
            <RadioButton Content="ソフト管理" GroupName="WorkCase"/>
            <RadioButton Content="問い合わせ" GroupName="WorkCase"/>
            <RadioButton Content="事務" GroupName="WorkCase"/>
        </WrapPanel>

        <!-- 開始/終了 -->
        <Button Grid.Row="3"
                x:Name="RecordButton"
                Content="開始"
                FontSize="18"
                Height="40"
                Background="#FFDFF5E1"
                Click="RecordButton_Click"/>

        <!-- 一覧 -->
        <ListView Grid.Row="4"
                  ItemsSource="{Binding Works}"
                  Margin="0,8,0,8">

            <ListView.View>
                <GridView>
                    <GridViewColumn Header="内容" DisplayMemberBinding="{Binding Content}" Width="140"/>
                    <GridViewColumn Header="開始" DisplayMemberBinding="{Binding Begin, StringFormat=HH:mm}" Width="70"/>
                    <GridViewColumn Header="終了" DisplayMemberBinding="{Binding End, StringFormat=HH:mm}" Width="70"/>
                    <GridViewColumn Header="工数" DisplayMemberBinding="{Binding Hour, StringFormat=hh\\:mm}" Width="60"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- ステータスバー -->
        <Border Grid.Row="5"
                Background="#FFF3F4F7"
                Padding="6"
                CornerRadius="6">

            <TextBlock x:Name="StatusText"
                       Text="準備完了"
                       Foreground="#FF666666"/>
        </Border>

    </Grid>
</Window>